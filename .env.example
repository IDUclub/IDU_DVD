# Сетевые связи сервиса: адреса внешних компонентов, к которым подключается
# приложение — Ollama, Qdrant, Redis, Kafka. Всё остальное имеет разумные
# дефолты в src/common/config/app_config.py — приложение запускается и без .env.
# Полный перечень переменных: .env.full.example (справочный) и docs/*/configuration.md
# (канонический список).
#
# Скопируйте в .env и поправьте:  cp .env.example .env

# --- Ollama (LLM-разметка/теги; резервный векторизатор) ---
# Дефолт в коде — общий стенд контура (http://a.dgx:11434, gpt-oss:20b).
# Для локального запуска переопределите адрес и модель:
DVD_OLLAMA_BASE=http://localhost:11434
DVD_OLLAMA_MODEL=qwen2.5:7b-instruct

# --- Векторизатор (GPU-сервис giga-vectorizer; дефолтный провайдер эмбеддингов) ---
# Отдельный сервис из репозитория giga-vectorizer (OpenAI-совместимый /v1/embeddings).
# Резервный вариант: DVD_EMBEDDINGS_PROVIDER=ollama (bge-m3; тогда DVD_VECTOR_SIZE=1024).
DVD_EMBEDDINGS_URL=http://localhost:8001

# --- Qdrant (векторное хранилище; локальная инфраструктура: make up) ---
# В docker compose переопределяется на имя сервиса compose-сети (http://qdrant:6333).
DVD_QDRANT_URL=http://localhost:6333
# DVD_QDRANT_API_KEY=

# --- Redis (статус парсинга + реестр документов/версий + Kafka-outbox) ---
# В docker compose переопределяется на redis://redis:6379/0.
DVD_REDIS_URL=redis://localhost:6379/0

# --- Админ-панель (/admin/ui) ---
# Обязательный пароль без небезопасного значения по умолчанию. Пока переменная не задана,
# вход в панель отключён. В production задайте её через секрет окружения.
DVD_ADMIN_PASSWORD=password

# --- Kafka (события об обработанных документах) ---
# Публикация выключена, пока не задан брокер (пустое значение = выключено).
# Тестовый контур (PLAINTEXT, без аутентификации):
# DVD_KAFKA_BOOTSTRAP_SERVERS=next.idulab.ru:9192,next.idulab.ru:9193,next.idulab.ru:9194
# Schema Registry контура уже является дефолтом в коде:
# DVD_KAFKA_SCHEMA_REGISTRY_URL=https://schema-registry.next.idulab.ru
