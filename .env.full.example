# Полный справочник переменных окружения (значения = дефолты из
# src/common/config/app_config.py). Для старта достаточно .env.example;
# канонический список с описаниями — docs/*/configuration.md: при добавлении
# настройки обновляйте её там и здесь.
#
# Списковые поля задаются в JSON-формате: DVD_ALLOWED_EXTENSIONS='[".docx",".txt"]'

# --- Ollama (LLM-разметка/теги; резервный векторизатор) ---
DVD_OLLAMA_BASE=http://a.dgx:11434
DVD_OLLAMA_MODEL=gpt-oss:20b
# Модель-векторизатор для DVD_EMBEDDINGS_PROVIDER=ollama (bge-m3 = 1024-d)
DVD_OLLAMA_EMBED_MODEL=bge-m3
DVD_OLLAMA_NUM_CTX=16384
DVD_OLLAMA_NUM_PREDICT=8192
DVD_OLLAMA_TIMEOUT=600.0

# --- Векторизатор (провайдер эмбеддингов) ---
# giga — GPU-сервис giga-vectorizer (OpenAI-совместимый /v1/embeddings, 2048-d);
# ollama — резервный вариант через /api/embed (bge-m3, 1024-d).
# Смена провайдера меняет векторное пространство; размерность определяется автоматически
# опросом векторизатора на старте (DVD_VECTOR_SIZE — лишь резерв).
# При DVD_COLLECTION_NAMESPACING=true будет создана новая физическая коллекция;
# документы нужно заново загрузить в неё.
DVD_EMBEDDINGS_PROVIDER=giga
DVD_EMBEDDINGS_URL=http://localhost:8001
DVD_EMBEDDINGS_MODEL=ai-sage/Giga-Embeddings-instruct
# Инструкция-префикс для эмбеддинга запросов (модель асимметричная: документы — без
# префикса, запросы — с ним). Перенос строки задаётся как \n.
DVD_EMBEDDINGS_QUERY_PROMPT="Instruct: Дан вопрос, необходимо найти абзац текста с ответом\nQuery: "
DVD_EMBEDDINGS_TIMEOUT=600.0

# --- Qdrant ---
DVD_QDRANT_URL=http://localhost:6333
# DVD_QDRANT_API_KEY=
# Базовое имя коллекции. При DVD_COLLECTION_NAMESPACING=true (по умолчанию) физическая
# коллекция = {base}__{модель}_{размерность}, напр. documents__giga_embeddings_instruct_2048;
# смена модели/размерности создаёт новое пространство, старое сохраняется. Реестр Redis
# неймспейсится так же. false — использовать имя как есть (прежнее поведение).
DVD_QDRANT_COLLECTION=documents
DVD_COLLECTION_NAMESPACING=true
# Резервное значение: реальная размерность определяется опросом векторизатора на старте и
# перезаписывает это число. Применяется как есть, только если векторизатор недоступен при старте
# (giga = 2048, bge-m3 = 1024).
DVD_VECTOR_SIZE=2048
DVD_EMBED_BATCH=32

# --- Redis (статус парсинга + реестр документов/версий + Kafka-outbox) ---
DVD_REDIS_URL=redis://localhost:6379/0
DVD_REDIS_JOB_TTL=86400

# --- Админ-панель (/admin/ui) ---
# Без пароля панель отвечает страницей с инструкцией по настройке и не создаёт сессию.
# DVD_ADMIN_PASSWORD=
DVD_ADMIN_SESSION_HOURS=12

# --- Поиск ---
DVD_SEARCH_LIMIT=10
DVD_MAX_CONTEXT_HEIGHT=6

# --- Связывание ссылок (ссылки на другие документы/пункты) ---
DVD_ENABLE_REFERENCE_LINKING=true
DVD_REF_PATTERN_LEARNING=false
DVD_REF_PATTERN_COLLECTION=ref_patterns

# --- Пайплайн парсинга ---
DVD_PARTITION_STRATEGY=hi_res
DVD_LANGUAGES=["rus","eng"]
DVD_WINDOW_CHARS=6000
DVD_WINDOW_MAX_ITEMS=22
DVD_OVERLAP_BLOCKS=3
DVD_SEMANTIC_MERGE_MAX_PASSES=1
DVD_SPLIT_SENTENCES=true
DVD_SENT_MIN_LEN=300

# --- Загрузка / корпус ---
# Сколько документов одновременно проходят GPU-стадии (LLM + эмбеддинги); лишние ждут в статусе
# "queued". 1 = одна видеокарта; повышать только при большем объёме GPU.
DVD_INGEST_CONCURRENCY=1
DVD_UPLOAD_DIR=./_uploads
# OCR-free форматы (unstructured). Скан-PDF/OCR отложен (тяжёлые torch/poppler/tesseract).
DVD_ALLOWED_EXTENSIONS=[".docx",".txt",".md",".html",".htm"]
# Дефолты общей метадаты, если загрузчик не передал их в форме (можно переопределить per-upload).
DVD_DEFAULT_DOC_TYPE=document
DVD_DEFAULT_CORPUS=default
# DVD_DEFAULT_LANG=ru

# --- Kafka (события об обработанных документах, фреймворк otteroad) ---
# Публикация выключена, пока не задан брокер (пустое значение = выключено).
# Тестовый контур (PLAINTEXT, без аутентификации):
# DVD_KAFKA_BOOTSTRAP_SERVERS=next.idulab.ru:9192,next.idulab.ru:9193,next.idulab.ru:9194
DVD_KAFKA_SCHEMA_REGISTRY_URL=https://schema-registry.next.idulab.ru
DVD_KAFKA_CLIENT_ID=idu-dvd
DVD_KAFKA_OUTBOX_KEY=dvd:kafka:outbox
DVD_KAFKA_DEAD_LETTER_KEY=dvd:kafka:outbox:dead
DVD_KAFKA_POLL_INTERVAL=1.0
DVD_KAFKA_RETRY_INTERVAL=5.0
DVD_KAFKA_MAX_ATTEMPTS=10

# --- Логирование ---
# JSON-логи пишутся в файл DVD_LOG_DIR/DVD_LOG_FILE и доступны через GET /system/logs.
DVD_LOG_DIR=./logs
DVD_LOG_FILE=app.log
DVD_LOG_LEVEL=INFO
