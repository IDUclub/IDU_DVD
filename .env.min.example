# Минимальная конфигурация: только то, что нужно для работы в контуре IDU или
# почти всегда переопределяется локально. Всё остальное имеет разумные дефолты
# в src/common/config/app_config.py — приложение запускается и без .env.
# Полный перечень переменных: .env.full.example (справочный) и docs/*/configuration.md
# (канонический список).
#
# Скопируйте в .env и поправьте:  cp .env.min.example .env

# --- Ollama (LLM-разметка/теги + векторизатор) ---
# Дефолт в коде — общий стенд контура (http://a.dgx:11434, gpt-oss:20b).
# Для локального запуска переопределите:
DVD_OLLAMA_BASE=http://localhost:11434
DVD_OLLAMA_MODEL=qwen2.5:7b-instruct

# --- Qdrant / Redis (локальная инфраструктура: make up) ---
# В docker compose переопределяются на имена сервисов compose-сети.
DVD_QDRANT_URL=http://localhost:6333
DVD_REDIS_URL=redis://localhost:6379/0

# --- Kafka (события об обработанных документах) ---
# Публикация выключена, пока не задан брокер. Schema Registry контура уже
# является дефолтом в коде. Тестовый контур (PLAINTEXT, без аутентификации):
# DVD_KAFKA_BOOTSTRAP_SERVERS=next.idulab.ru:9192,next.idulab.ru:9193,next.idulab.ru:9194
